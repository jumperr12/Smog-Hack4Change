# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# ─── OpenRouteService ───────────────────────────────────────────────────────
# Darmowy klucz API: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=twoj_klucz_ors_tutaj
ORS_ALTERNATIVE_ROUTES_COUNT=3

# ─── GIOŚ ────────────────────────────────────────────────────────────────────
# Oficjalne API GIOŚ — bez klucza, działa od razu
# Zmień na /pjp-api/v1/rest gdy stara wersja zostanie wyłączona
GIOS_BASE_URL=https://api.gios.gov.pl/pjp-api/rest

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_TTL_STACJE=86400
CACHE_TTL_POMIARY=3600

# ─── Obszar geograficzny ─────────────────────────────────────────────────────
# Domyślnie Trójmiasto — zmień żeby obsługiwać inne miasto
BBOX_MIN_LAT=54.25
BBOX_MIN_LON=18.40
BBOX_MAX_LAT=54.60
BBOX_MAX_LON=18.80

# ─── Providery ───────────────────────────────────────────────────────────────
# Dostępne: gios | (w przyszłości: airly, openaq)
AIR_QUALITY_PROVIDER=gios
# Dostępne: openrouteservice | (w przyszłości: graphhopper, osrm)
ROUTING_PROVIDER=openrouteservice

# ─── Próbkowanie smogu ───────────────────────────────────────────────────────
# Co ile metrów pobierać wartość PM2.5 wzdłuż trasy
SAMPLING_INTERVAL_M=200.0
