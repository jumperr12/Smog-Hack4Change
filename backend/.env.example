# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env

# ─── OpenRouteService ───────────────────────────────────────────────────────
# Darmowy klucz API: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=twoj_klucz_ors_tutaj
ORS_ALTERNATIVE_ROUTES_COUNT=3

# ─── GIOŚ ────────────────────────────────────────────────────────────────────
# Oficjalne API GIOŚ — bez klucza, działa od razu
# Zmień na /pjp-api/v1/rest gdy stara wersja zostanie wyłączona
GIOS_BASE_URL=https://api.gios.gov.pl/pjp-api/v1/rest

# ─── Open-Meteo Air Quality ──────────────────────────────────────────────────
# Model CAMS (~11 km) — bez klucza, zwraca PM2.5/PM10 dla dowolnego punktu
# (pokrywa też obszary bez stacji, np. Półwysep Helski)
OPENMETEO_BASE_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_TTL_STACJE=86400
CACHE_TTL_POMIARY=3600

# ─── Obszar geograficzny ─────────────────────────────────────────────────────
# Województwo pomorskie — stacje GIOŚ dla całego regionu
# Zmień na mniejszy bbox żeby pobierać stacje tylko dla konkretnego miasta
BBOX_MIN_LAT=53.50
BBOX_MIN_LON=16.85
BBOX_MAX_LAT=54.90
BBOX_MAX_LON=19.50

# ─── Providery ───────────────────────────────────────────────────────────────
# Dostępne: gios (stacje, realny pomiar) | openmeteo (model, pokrywa każdy punkt)
# (w przyszłości: airly, openaq)
AIR_QUALITY_PROVIDER=openmeteo
# Dostępne: openrouteservice | (w przyszłości: graphhopper, osrm)
ROUTING_PROVIDER=openrouteservice

# ─── Próbkowanie smogu ───────────────────────────────────────────────────────
# Co ile metrów pobierać wartość PM2.5 wzdłuż trasy
SAMPLING_INTERVAL_M=200.0
